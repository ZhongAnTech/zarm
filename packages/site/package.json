{
  "name": "site",
  "version": "0.0.36",
  "private": true,
  "scripts": {
    "build": "rimraf assets && mkdir assets && touch assets/CNAME && echo 'zarm.design' > assets/CNAME && zarm deploy",
    "clean": "rimraf assets",
    "deploy": "pnpm build && gh-pages -d assets",
    "start": "zarm dev"
  },
