    "clipboard": "^2.0.11",
    "prop-types": "^15.8.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-helmet": "^6.1.0",
    "react-intl": "^5.25.1",
    "react-router-dom": "^5.3.4",
    "zarm": "workspace:^"
  },
  "devDependencies": {
    "@babel/standalone": "7.29.7",
    "@sentry/browser": "^7.120.4",
    "@types/react": "^19.2.17",
