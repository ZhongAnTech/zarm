{
  "name": "zarm",
  "version": "3.4.0",
  "description": "基于 React 的移动端UI库",
  "keywords": [
    "react",
    "react-ui",
    "react-component",
    "zarm",
    "zarm-ui",
    "zarm-mobile",
    "component",
    "components",
    "ui",
    "framework",
    "frontend",
    "mobile"
  ],
  "bugs": {
    "url": "https://github.com/ZhongAnTech/zarm/issues"
  },
  "repository": "git://github.com/ZhongAnTech/zarm",
  "license": "MIT",
  "sideEffects": [
    "dist/*",
    "es/react19.js",
    "lib/react19.js",
    "react19.js",
    "src/react19.ts",
    "src/style/*",
    "src/**/style/*",
    "es/**/style/*",
    "lib/**/style/*"
  ],
  "main": "lib/index.js",
  "module": "es/index.js",
  "typings": "lib/index.d.ts",
  "directories": {
    "lib": "lib",
    "test": "__tests__"
  },
  "files": [
    "lib",
    "es",
    "dist",
    "types",
    "react19.js",
    "react19.d.ts"
  ],
  "scripts": {
    "build": "pnpm build:lib && pnpm build:es && pnpm build:umd",
    "build:es": "rimraf es && tsc --outDir es && zarm build --mode es --path src --out-dir es --copy-files --build-css",
    "build:lib": "rimraf lib && tsc --outDir lib && zarm build --mode lib --path src --out-dir lib --copy-files --build-css",
    "build:umd": "rimraf dist && zarm build --mode umd --path src/style/entry.ts,src/index.ts --out-dir dist --library-name zarm && zarm build --mode umd-ugly --path src/style/entry.ts,src/index.ts --out-dir dist --library-name zarm",
    "clean": "rimraf lib es dist coverage",
    "coverage": "rimraf coverage && pnpm test -c",
    "install-react-16": "pnpm add --save-dev --lockfile=false react@16.8.0 react-dom@16.8.0 @types/react@16.14.68 @types/react-dom@16.9.25 @testing-library/react@12.1.5",
    "lint": "pnpm lint:tsc && pnpm lint:script && pnpm lint:style",
    "lint:script": "eslint --ext .ts,.tsx src",
    "lint:style": "stylelint \"src/**/*.scss\" --syntax scss",
    "lint:tsc": "tsc --noEmit",
    "release": "bash scripts/release.sh",
    "test": "TZ=UTC zarm test -s scripts/jest/setup.js"
  },
  "browserslist": [
    "last 2 versions",
    "Firefox ESR",
    "> 1%",
    "ie >= 9",
    "iOS >= 7",
    "Android >= 4"
  ],
  "dependencies": {
    "@better-scroll/core": "^2.3.1",
    "@better-scroll/wheel": "^2.3.1",
    "@floating-ui/react-dom-interactions": "^0.9.1",
    "@use-gesture/react": "^10.1.1",
    "@zarm-design/bem": "workspace:^",
    "@zarm-design/icons": "workspace:^",
    "ahooks": "^3.7.6",
    "better-scroll": "2.3.1",
    "classnames": "^2.3.1",
    "color": "^3.1.3",
    "dayjs": "^1.11.3",
    "intersection-observer": "^0.12.2",
    "lodash": "^4.17.15",
    "normalize.css": "8.0.1",
    "raf": "^3.4.1",
    "react-transition-group": "^4.4.2"
  },
  "devDependencies": {
    "@babel/runtime": "^7.14.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.4.3",
    "@types/lodash": "^4.14.182",
    "@types/node": "^15.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-transition-group": "^4.4.5",
    "@types/testing-library__jest-dom": "^5.9.1",
    "@zarm-design/cli": "workspace:^",
    "chalk": "^4.1.1",
    "dekko": "^0.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ts-jest": "^26.5.0",
    "typescript": "~4.5.0"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "bundlesize": [
    {
      "path": "./dist/zarm.min.js",
      "maxSize": "130 kB"
    },
    {
      "path": "./dist/zarm.min.css",
      "maxSize": "25 kB"
    }
  ],
  "tags": [
    "zarm",
    "zarm-ui",
    "zhongan",
    "component",
    "components",
    "react",
    "react-component",
    "framework",
    "frontend",
    "ui"
  ]
}
