24,9],\"65\":[4,21,9],\"66\":[7,24,10],\"67\":[11,28,10],\"68\":[11,28,10],\"69\":[9,26,11],\"70\":[7,24,9],\"71\":[4,21,9],\"72\":[7,24,10],\"73\":[11,28,10]},\"averageFieldLength\":[7.337837837837838,286.5810810810811,7.162162162162162],\"storedFields\":{\"0\":{\"title\":\"Zarm\",\"summary\":\"Zarm 是众安科技基于 React 研发的一款适用于企业级的移动端 UI 组件库。 Zarm （读音 /zɑːm/，中文可发音为 扎姆）的命名，灵感来源于众安保险秉承的理念：做有温度的保险。Zarm = za + warm，za 代表 “众安”，warm 有 “温暖” 的含义，以重合的 “a” 字母为中心，各取左右两部分。追求极致的用户体验，致力于做有温度…\",\"type\":\"doc\",\"version\":\"3.x\",\"url\":\"#/docs/about-zarm\"},\"1\":{\"title\":\"快速上手\",\"summary\":\"通过本章节，可以带你快速了解 Zarm 的安装方法和基本使用。 npm $ npm install zarm --save pnpm $ pnpm add zarm 使用 import React from 'react'; import { render } from 'react-dom'; import { ConfigProvider, Button…\",\"type\":\"doc\",\"version\":\"3.x\",\"url\":\"#/docs/installation\"},\"2\":{\"title\":\"定制主题\",\"summary\":\"Zarm 的样式使用了 scss 和 css 变量 相结合做为开发语言，并定义了一系列全局/组件的样式变量，你可以根据需求进行相应调整，实现定制主题的能力。 Zarm 提供了一个 React 组件 ConfigProvider 用于快速定制主题。 品牌标准色 目前的默认的品牌标准色是 00bc70 ，如果需要使用其他颜色，可以参考下面的方案。 暗黑主题 除了…\",\"type\":\"doc\",\"version\":\"3.x\",\"url\":\"#/docs/customize-theme\"},\"3\":{\"title\":\"国际化\",\"summary\":\"Zarm 目前的默认文案是中文，如果需要使用其他语言，可以参考下面的方案。 ConfigProvider Zarm 提供了一个 React 组件 ConfigProvider 用于全局配置国际化文案。 import { ConfigProvider } from 'zarm'; import zhCN from 'zarm/lib/config-provid…\",\"type\":\"doc\",\"version\":\"3.x\",\"url\":\"#/docs/i18n\"},\"4\":{\"title\":\"兼容性支持\",\"summary\":\"Zarm 实现过程中，部分组件使用了较新的 API，这些 API 在低版本浏览器中可能会有兼容问题，导致运行代码逻辑执行失败或者报错。 本文档将公开 Zarm 中涉及到的兼容性不足的 API 的使用，帮助开发者根据项目实际场景选择是否需要添加相关的 polyfill。 API 使用情况列表 使用到的 API 涉及组件 引入方式 最低兼容版本 推荐的 poly…\",\"type\":\"doc\",\"version\":\"3.x\",\"url\":\"#/docs/polyfill\"},\"5\":{\"title\":\"从 v2 到 v3\",\"summary\":\"本文档将帮助你从 v2 版本升级到 v3 组件重构与移除 - 移除 Cell 组件，更名为 List - 移除 StackPicker 组件，移至 Cascader - 移除 Drag 组件 - Loading 组件在 v3 版本中废弃，移至 Toast.show({ icon: 'loading' }) 指令式调用 - 移除 ActivityIndicat…\",\"type\":\"doc\",\"version\":\"3.x\",\"url\":\"#/docs/migration-v3\"},\"6\":{\"title\":\"React 版本兼容\",\"summary\":\"Zarm 支持 React 和 React DOM 16.8 、 17 、 18 、 19 。应用中的 React 与 React DOM 应保持相同的主版本。 React 16、17、18 这些版本无需额外配置： import { Button, Toast } from 'zarm'; ReactDOM.render( Button , mountNod…\",\"type\":\"doc\",\"version\":\"3.x\",\"url\":\"#/docs/react-19\"},\"7\":{\"title\":\"贡献 Zarm\",\"summary\":\"安装 git clone 拉取代码仓库后，安装依赖 使用 pnpm 安装工作区依赖 $ pnpm install 然后, 你可以运行 Zarm Design 的本地站点。 开发 h5 端 $ pnpm dev 检查 代码风格检查。 $ pnpm lint ts/js 文件检查 $ pnpm lint:script 样式文件检查 $ pnpm lint:sty…\",\"type\":\"doc\",\"version\":\"3.x\",\"url\":\"#/docs/contributing\"},\"8\":{\"title\":\"版本更新日志\",\"summary\":\"Unreleased v3.4.2 - Bug Fix - [Build] 修复发布包 package.json 中包含 workspace:^ 依赖导致外部项目安装失败的问题 v3.4.1 - Bug Fix - [React 19] 移除组件静态 defaultProps 依赖，改为组件内部显式合并默认属性，兼容 React 19 不再处理函数组件 de…\",\"type\":\"doc\",\"version\":\"3.x\",\"url\":\"#/docs/changelog\"},\"9\":{\"title\":\"Button 按钮\",\"summary\":\"基本用法 import { Button } from 'zarm'; ReactDOM.render( < default primary , mountNode, ); 块级按钮 import { Button } from 'zarm'; ReactDOM.render( < default default disabled primary prima…\",\"type\":\"component\",\"version\":\"3.x\",\"url\":\"#/components/button\"},\"10\":{\"title\":\"Icon 图标\",\"summary\":\"基本用法 import { Grid, Icon } from 'zarm'; const MyIcon = Icon.createFromIconfont('//lf1-cdn-tos.bytegoofy.com/obj/iconpark/svg 20337 14.627ee457cf7594fbbce6d5e14b8c29ef.js'); // gene…\",\"type\":\"component\",\"version\":\"3.x\",\"url\":\"#/components/icon\"},\"11\":{\"title\":\"Input 文本框\",\"summary\":\"基本用法 import { useState, useRef } from 'react'; import { Input, List, Button } from 'zarm'; const Demo = () = { const focusInput = useRef(); const [title, setTitle] = useState(''); …\",\"type\":\"component\",\"version\":\"3.x\",\"url\":\"#/components/input\"},\"12\":{\"title\":\"CustomInput 自定义输入框\",\"summary\":\"基本用法 import { useState, useRef } from 'react'; import { CustomInput, List, Button } from 'zarm'; const Demo = () = { const focusInpu