{
  "name": "root",
  "private": true,
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "scripts": {
    "build": "pnpm --filter zarm build",
    "clean": "pnpm --recursive clean && lerna clean -y",
    "deploy": "pnpm --filter site deploy",
    "deploy:build": "pnpm --filter site build",
    "dev": "pnpm --filter site start",
    "postinstall": "pnpm --filter @zarm-design/cli build && pnpm --filter @zarm-design/bem build && pnpm --filter @zarm-design/icons build",
    "lint": "pnpm lint:tsc && pnpm lint:script && pnpm lint:style",
    "lint:script": "eslint --ext .ts,.tsx,.js,.jsx packages",
    "lint:style": "stylelint \"packages/**/*.scss\" --syntax scss",
    "lint:tsc": "tsc --noEmit",
    "prepublishOnly": "pnpm lint && pnpm build && pnpm test",
    "prettier": "prettier --write -c '**/*.{js,jsx,ts,tsx,html,md,json}'",
    "release": "lerna publish",
    "sort": "npx sort-package-json \"package.json\" \"packages/*/package.json\"",
    "test": "pnpm --recursive --filter '!site' test"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,html,md,json}": [
      "prettier --write --no-error-on-unmatched-pattern"
    ],
    "*.scss": [
      "stylelint --syntax scss"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/eslint-parser": "^7.29.7",
    "@babel/eslint-plugin": "^7.29.7",
    "@babel/plugin-transform-class-properties": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.20.1",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "browserslist": "^4.28.6",
    "concurrently": "^9.2.1",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "8.10.2",
    "eslint-config-za": "2.4.0-alpha.3",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "4.6.2",
    "husky": "^8.0.3",
    "lerna": "^9.0.7",
    "lint-staged": "^16.4.0",
    "prettier": "^2.8.8",
    "prettier-plugin-organize-imports": "^3.2.4",
    "prettier-plugin-packagejson": "^2.5.22",
    "pnpm": "10.34.4",
    "rimraf": "^6.1.3",
    "stylelint": "13.13.1",
    "stylelint-config-za": "0.3.0",
    "stylelint-scss": "3.19.0",
    "typescript": "~4.9.5"
  }
}
